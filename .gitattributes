# Handle line endings automatically
* text=auto

# Force LF on scripts for consistency
*.sh text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf

# Batch files must have CRLF for Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text
